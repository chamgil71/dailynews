{
  "version": 2,
  "name": "ai-news-daily",
  "builds": [
    {
      "src": "publish/**",
      "use": "@vercel/static"
    },
    { "src": "api/subscribe.py",   "use": "@vercel/python" },
    { "src": "api/confirm.py",     "use": "@vercel/python" },
    { "src": "api/unsubscribe.py", "use": "@vercel/python" },
    { "src": "api/manage.py",      "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/subscribe",            "dest": "/api/subscribe.py" },
    { "src": "/api/confirm",              "dest": "/api/confirm.py" },
    { "src": "/api/unsubscribe",          "dest": "/api/unsubscribe.py" },
    { "src": "/api/manage",               "dest": "/api/manage.py" },
    { "src": "/ads.txt",                  "dest": "/publish/ads.txt" },
    { "src": "/subscribe",                "dest": "/publish/subscribe.html" },
    { "src": "/privacy",                  "dest": "/publish/privacy.html" },
    { "src": "/about",                    "dest": "/publish/about.html" },
    { "src": "/",                          "dest": "/publish/index.html" },
    { "src": "/archive",                   "dest": "/publish/archive.html" },
    { "src": "/reports\\.json",            "dest": "/publish/reports.json" },
    { "src": "/reports-data\\.json",       "dest": "/publish/reports-data.json" },
    { "src": "/stock",                     "dest": "/publish/stock/index.html" },
    { "src": "/stock/",                    "dest": "/publish/stock/index.html" },
    { "src": "/stock/archive",             "dest": "/publish/stock/archive.html" },
    { "src": "/stock/(\\d{4}-\\d{2}-\\d{2})", "dest": "/publish/stock/$1.html" },
    { "src": "/ai-issue",                     "dest": "/publish/ai-issue/index.html" },
    { "src": "/ai-issue/",                    "dest": "/publish/ai-issue/index.html" },
    { "src": "/ai-issue/archive",             "dest": "/publish/ai-issue/archive.html" },
    { "src": "/ai-issue/(\\d{4}-\\d{2}-\\d{2})", "dest": "/publish/ai-issue/$1.html" },
    { "src": "/ai-issue/(\\d{4}-\\d{2}-\\d{2})\\.json", "dest": "/publish/ai-issue/$1.json" },
    { "src": "/(\\d{4}-\\d{2}-\\d{2})",       "dest": "/publish/news/$1.html" },
    { "src": "/news/(\\d{4}-\\d{2}-\\d{2})",  "dest": "/publish/news/$1.html" },
    { "src": "/(.*)\\.html",                   "dest": "/publish/$1.html" },
    { "src": "/(.*)",                          "dest": "/publish/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control",          "value": "public, max-age=3600" }
      ]
    }
  ]
}
