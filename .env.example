# .env.example — 로컬 개발용 환경변수 샘플
# 실제 .env 파일을 만들어 값을 채우세요. .env는 절대 커밋하지 마세요.

# ── LLM 선택 ─────────────────────────────────────────────────────────────────
# gemini | claude | gpt 중 하나를 선택
LLM_PROVIDER=gemini

# ── Gemini (기본값) ───────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
# 모델 재정의 (기본값 사용 시 주석 유지)
# GEMINI_MODEL_FULL=gemini-3.5-flash
# GEMINI_MODEL_MINI=gemini-3.1-flash-lite
# GEMINI_MODEL_FALLBACK=gemini-2.5-flash

# ── Claude ────────────────────────────────────────────────────────────────────
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...

# ── GPT ───────────────────────────────────────────────────────────────────────
# LLM_PROVIDER=gpt
# OPENAI_API_KEY=sk-...

# ── 이메일 (Gmail SMTP) ───────────────────────────────────────────────────────
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
RECIPIENT_EMAILS=you@example.com,other@example.com

# ── 사이트 설정 ───────────────────────────────────────────────────────────────
SITE_BASE_URL=https://your-project.vercel.app
SITE_TITLE=Daily News Brief
SUBSCRIBE_URL=https://your-project.vercel.app/subscribe

# ── 보안 키 ───────────────────────────────────────────────────────────────────
UNSUBSCRIBE_SECRET=your-random-secret-32chars

# ── Supabase (구독 시스템) ────────────────────────────────────────────────────
# 대시보드: https://supabase.com/dashboard/project/{project_id}
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key   # Settings → API → service_role

# ── GitHub Contents API ───────────────────────────────────────────────────────
GH_CONTENTS_TOKEN=ghp_...
GITHUB_REPOSITORY=owner/repo

# ── 네이버 뉴스 API ───────────────────────────────────────────────────────────
# 용도: 주식 국내뉴스 보완 수집 (core/stock/collector.py)
# 발급: https://developers.naver.com → 애플리케이션 등록
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ── 노션 연동 ─────────────────────────────────────────────────────────────────
NOTION_API_KEY=ntn_...
NOTION_DATABASE_ID_NEWS=your-notion-news-database-id
NOTION_DATABASE_ID_STOCK=your-notion-stock-database-id
NOTION_DATABASE_ID_AI_ISSUE=your-notion-ai-issue-database-id

# ── 텔레그램 ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-channel-id          # 뉴스·AI이슈 채널 (카드뉴스 포함)
TELEGRAM_CHAT_ID_STOCK=your-stock-channel-id  # 주식 전용 채널 (카드뉴스 포함)

# ── SNS 카드뉴스 — Instagram ──────────────────────────────────────────────────
# 발급: Meta for Developers → instagram_content_publish 권한
# 토큰 60일 유효 — 주기적 갱신 필요
INSTAGRAM_ACCESS_TOKEN=EAAxxxxx...
INSTAGRAM_BUSINESS_ACCOUNT_ID=123456789012345  # Instagram Business 계정 숫자 ID

# ── SNS 카드뉴스 — Facebook Page ─────────────────────────────────────────────
# 발급: Meta for Developers → Pages API
# graph.facebook.com/v21.0/me/accounts?access_token={long_lived_token} 로 Page ID 확인
FACEBOOK_PAGE_ID=your-facebook-page-id
META_PAGE_ACCESS_TOKEN=EAAxxxxx...  # Page Access Token

# ── SNS 카드뉴스 — Threads ────────────────────────────────────────────────────
# 발급: Meta for Developers → Threads API
# THREADS_USER_ID: graph.threads.net/v1.0/me?fields=id&access_token={token}
THREADS_USER_ID=your-threads-user-id
THREADS_ACCESS_TOKEN=THAATxxxxx...

# ── SNS 카드뉴스 — Twitter/X ─────────────────────────────────────────────────
# 발급: developer.twitter.com → Projects & Apps → OAuth 1.0a
# TWITTER_API_KEY=your-api-key
# TWITTER_API_SECRET=your-api-secret
# TWITTER_ACCESS_TOKEN=your-access-token
# TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret

# ── 테마 설정 (기본값: editorial) ─────────────────────────────────────────────
# classic | minimal | ink | forest | editorial | terminal
# SITE_THEME=classic
# THEME_NEWS=editorial
# THEME_STOCK=classic
# THEME_EMAIL=classic

# ── 푸터 생성기 (선택) ────────────────────────────────────────────────────────
# FOOTER_GENERATOR=github-actions
# FOOTER_REPO=owner/repo
