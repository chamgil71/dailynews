# .env.example — 로컬 개발용 환경변수 샘플
# 실제 .env 파일을 만들어 값을 채우세요. .env는 절대 커밋하지 마세요.

# ── LLM 선택 ─────────────────────────────────────────────────────────────────
# gemini | claude | gpt 중 하나를 선택
LLM_PROVIDER=gemini

# ── Gemini (기본값) ───────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
# 모델 재정의 (기본값 사용 시 주석 유지)
# GEMINI_MODEL_FULL=gemini-3.5-flash
# GEMINI_MODEL_MINI=gemini-3.1-flash-lite
# GEMINI_MODEL_FALLBACK=gemini-2.5-flash

# ── Claude ────────────────────────────────────────────────────────────────────
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...

# ── GPT ───────────────────────────────────────────────────────────────────────
# LLM_PROVIDER=gpt
# OPENAI_API_KEY=sk-...

# ── 이메일 (Gmail SMTP) ───────────────────────────────────────────────────────
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
RECIPIENT_EMAILS=you@example.com,other@example.com

# ── 사이트 설정 ───────────────────────────────────────────────────────────────
SITE_BASE_URL=https://your-project.vercel.app
SITE_TITLE=Daily News Brief
SUBSCRIBE_URL=https://your-project.vercel.app/subscribe

# ── GitHub (구독자 파일 읽기/쓰기용) ─────────────────────────────────────────
GH_CONTENTS_TOKEN=ghp_...
GITHUB_REPOSITORY=owner/repo

# ── 구독 취소 보안 키 ─────────────────────────────────────────────────────────
UNSUBSCRIBE_SECRET=your-random-secret-32chars

# ── 네이버 뉴스 API ───────────────────────────────────────────────────────────
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ── Supabase (구독 시스템) ────────────────────────────────────────────────────
SUPABASE_URL=https://syxpwvmniwzohmxmvlyl.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key   # Supabase 대시보드 → Settings → API → service_role

# ── 노션 연동 ─────────────────────────────────────────────────────────────────
NOTION_API_KEY=ntn_...
NOTION_DATABASE_ID_NEWS=your-notion-news-database-id
NOTION_DATABASE_ID_STOCK=your-notion-stock-database-id
NOTION_DATABASE_ID_AI_ISSUE=your-notion-ai-issue-database-id

# ── 텔레그램 알림 ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id-or-channel-id        # 뉴스·AI이슈 채널
TELEGRAM_CHAT_ID_STOCK=your-stock-channel-id                 # 주식 전용 채널

# ── SNS 카드뉴스 (Instagram / Twitter·X) ─────────────────────────────────────
# Instagram Graph API v21.0 (Business 계정 필요)
# 발급: Meta for Developers → Graph API Explorer → instagram_content_publish 권한
INSTAGRAM_ACCESS_TOKEN=EAAxxxxx...                           # 장기 액세스 토큰 (60일, 주기적 갱신 필요)
INSTAGRAM_BUSINESS_ACCOUNT_ID=123456789012345               # Business 계정 숫자 ID

# Twitter / X API v2 (Developer Portal 앱 필요, OAuth 1.0a)
# 발급: developer.twitter.com → Projects & Apps → 앱 키 생성
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret

# ── Vercel (수동 배포 시) ─────────────────────────────────────────────────────
# VERCEL_TOKEN=your-vercel-token
# VERCEL_ORG_ID=your-vercel-org-id
# VERCEL_PROJECT_ID=your-vercel-project-id

# ── 테마 설정 (기본값: classic) ───────────────────────────────────────────────
# classic | minimal | ink | forest | editorial | terminal
# SITE_THEME=classic
# THEME_NEWS=editorial
# THEME_STOCK=classic
# THEME_EMAIL=classic

# ── 푸터 생성기 (선택) ────────────────────────────────────────────────────────
# FOOTER_GENERATOR=github-actions
# FOOTER_REPO=owner/repo
