# .env.example — 로컬 개발용 환경변수 샘플
# 실제 .env 파일을 만들어 값을 채우세요. .env는 절대 커밋하지 마세요.

# ── 이메일 (Gmail SMTP) ───────────────────────────────────────────────────────
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx   # Google 앱 비밀번호 (16자리)
RECIPIENT_EMAILS=you@example.com,other@example.com

# ── 구독 취소 (Vercel 서버리스 함수용) ───────────────────────────────────────
UNSUBSCRIBE_SECRET=your-random-secret-32chars
SITE_BASE_URL=https://your-project.vercel.app
GH_CONTENTS_TOKEN=ghp_...
GITHUB_REPOSITORY=owner/repo

# ── 테마 설정 (기본값: classic) ───────────────────────────────────────────────
# classic | minimal | ink | forest | editorial | terminal
# SITE_THEME=classic          # 전체 기본 테마
# THEME_NEWS=editorial        # 뉴스브리핑 개별 테마
# THEME_STOCK=classic         # 주식시황 개별 테마
# THEME_EMAIL=classic         # 이메일 개별 테마

# ── LLM 선택 (기본값: gemini) ─────────────────────────────────────────────────
# LLM_PROVIDER=gemini | claude | gpt  중 하나를 선택해 주석 해제

# ── Gemini (기본값) ───────────────────────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIza...

# ── Claude ────────────────────────────────────────────────────────────────────
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...

# ── GPT ───────────────────────────────────────────────────────────────────────
# LLM_PROVIDER=gpt
# OPENAI_API_KEY=sk-...
