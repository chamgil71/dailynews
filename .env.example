# .env.example — 로컬 개발용 환경변수 샘플
# 실제 .env 파일을 만들어 값을 채우세요. .env는 절대 커밋하지 마세요.

# ── 이메일 ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RECIPIENT_EMAIL=you@example.com,other@example.com

# ── LLM 선택 (기본값: gemini) ─────────────────────────────────────────────────
# LLM_PROVIDER=gemini | claude | gpt  중 하나를 선택해 주석 해제

# ── Gemini (기본값) ───────────────────────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIza...

# ── Claude ────────────────────────────────────────────────────────────────────
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...

# ── GPT ───────────────────────────────────────────────────────────────────────
# LLM_PROVIDER=gpt
# OPENAI_API_KEY=sk-...
