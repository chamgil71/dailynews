# .env.example — 로컬 개발용 환경변수 샘플
# 이 파일을 복사하여 .env를 만들고 실제 값을 채우세요.
# .env는 절대 커밋하지 마세요 (.gitignore 적용됨)
# 각 키의 상세 획득 방법: docs/env_spec.md 참조

# ── LLM 설정 ──────────────────────────────────────────────────────────────────
# 획득: https://aistudio.google.com/apikey → "Create API Key"
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIza...

# 모델 재정의 (기본값 사용 시 주석 유지)
# GEMINI_MODEL_FULL=gemini-3.5-flash
# GEMINI_MODEL_MINI=gemini-3.1-flash-lite
# GEMINI_MODEL_FALLBACK=gemini-2.5-flash

# 대체 LLM (미사용 시 주석 유지)
# ANTHROPIC_API_KEY=sk-ant-...   # 획득: https://console.anthropic.com/ → API Keys
# OPENAI_API_KEY=sk-...          # 획득: https://platform.openai.com/api-keys

# ── 이메일 (Gmail SMTP) ───────────────────────────────────────────────────────
# GMAIL_APP_PASSWORD 획득: Google 계정 → 보안 → 2단계 인증 ON →
#   "앱 비밀번호" → 앱: 메일, 기기: 기타(이름 직접 입력) → 생성
#   ※ 실제 Gmail 로그인 비밀번호가 아님, 16자리 앱 전용 비밀번호
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# 구독 DB(Supabase) 조회 실패 시 비상 폴백 수신자 (쉼표 구분)
RECIPIENT_EMAILS=you@example.com,other@example.com

# ── 사이트 설정 ───────────────────────────────────────────────────────────────
SITE_BASE_URL=https://your-project.vercel.app
SITE_TITLE=AI News Brief
SUBSCRIBE_URL=https://your-project.vercel.app/subscribe

# ── 보안 키 ───────────────────────────────────────────────────────────────────
# UNSUBSCRIBE_SECRET: 이메일 구독취소 링크 위변조 방지용 HMAC 서명 비밀값
#   → 임의 문자열(32자 권장). GitHub Secrets · Vercel 환경변수 모두 동일 값 사용
#   → 획득: 직접 생성 (예: python -c "import secrets; print(secrets.token_hex(16))")
UNSUBSCRIBE_SECRET=your-random-secret-32chars

# ── Supabase (구독 시스템) ────────────────────────────────────────────────────
# 획득: https://supabase.com/dashboard → 프로젝트 선택 → Settings → API
#   SUPABASE_URL      → "Project URL" 항목
#   SUPABASE_SERVICE_KEY → "service_role" 키 (눈 아이콘 클릭해야 표시)
#   ※ anon 키(VITE_SUPABASE_ANON_KEY)가 아님 — service_role 키만 RLS 우회 가능
#   ※ Vercel 서버리스 함수(/api/*.py)에도 동일 값을 Vercel 대시보드에 등록 필요
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── GitHub Contents API (레거시) ──────────────────────────────────────────────
# ⚠️ 현재 미사용 — Supabase 구독 시스템 전환으로 폐기 예정
# 획득: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
#   권한: Contents(Read & Write), Metadata(Read)
GH_CONTENTS_TOKEN=github_pat_...
GITHUB_REPOSITORY=owner/repo

# ── 네이버 뉴스 API ───────────────────────────────────────────────────────────
# 획득: https://developers.naver.com/apps → 애플리케이션 등록
#   → 사용 API: "검색" 체크 → Client ID / Client Secret 발급
#   사용처: core/stock/collector.py::collect_news_ko() (주식 국내뉴스 보완)
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ── 노션 연동 ─────────────────────────────────────────────────────────────────
# NOTION_API_KEY 획득: https://www.notion.so/my-integrations → "+ New integration" → 생성
#   → Integration Token (ntn_로 시작)
# NOTION_DATABASE_ID 획득: 노션 DB 페이지 → 공유 → 링크 복사
#   → URL의 마지막 32자리 hex (대시 제외)
#   예: notion.so/xxx/324fae739c2b802e87dce959cad42420?v=... → 324fae739c2b802e87dce959cad42420
NOTION_API_KEY=ntn_...
NOTION_DATABASE_ID_NEWS=your-notion-news-database-id
NOTION_DATABASE_ID_STOCK=your-notion-stock-database-id
NOTION_DATABASE_ID_AI_ISSUE=your-notion-ai-issue-database-id

# ── 텔레그램 알림 ─────────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN 획득: 텔레그램 앱 → @BotFather → /newbot → 토큰 발급
# TELEGRAM_CHAT_ID 획득: 채널에 봇 추가 후 @userinfobot 또는 API로 확인
#   채널/슈퍼그룹 ID는 반드시 -100 접두사 포함 (예: -1001234567890)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-channel-id
TELEGRAM_CHAT_ID_STOCK=your-stock-channel-id

# ── 테마 설정 ─────────────────────────────────────────────────────────────────
# classic | minimal | ink | forest | editorial | terminal
THEME_NEWS=editorial
# SITE_THEME=classic
# THEME_STOCK=classic
# THEME_EMAIL=classic

# ── SNS 카드뉴스 — Instagram ──────────────────────────────────────────────────
# 획득: https://developers.facebook.com → My Apps → 앱 선택
#   → Graph API Explorer → instagram_content_publish 권한으로 장기 토큰 생성
#   → INSTAGRAM_BUSINESS_ACCOUNT_ID: /me/accounts → instagram_business_account.id
#   ⚠️ 60일마다 만료 — 만료 전 갱신 필요
INSTAGRAM_ACCESS_TOKEN=EAAxxxxx...
INSTAGRAM_BUSINESS_ACCOUNT_ID=123456789012345

# ── SNS 카드뉴스 — Facebook ──────────────────────────────────────────────────
# 획득: Instagram 장기 토큰 생성 후
#   graph.facebook.com/v21.0/me/accounts?access_token={장기토큰}
#   → data[0].id = FACEBOOK_PAGE_ID, data[0].access_token = META_PAGE_ACCESS_TOKEN
FACEBOOK_PAGE_ID=your-facebook-page-id
META_PAGE_ACCESS_TOKEN=EAAxxxxx...

# ── SNS 카드뉴스 — Threads ────────────────────────────────────────────────────
# 획득: https://developers.facebook.com → Threads API 앱 설정
#   → Graph API Explorer → threads_content_publish 권한으로 토큰 생성
#   → THREADS_USER_ID: /me?fields=id (Threads 사용자 ID, Instagram ID와 다름)
THREADS_USER_ID=your-threads-user-id
THREADS_ACCESS_TOKEN=THAATxxxxx...

# ── SNS 카드뉴스 — Twitter/X (현재 미발급) ───────────────────────────────────
# 획득: https://developer.twitter.com → 프로젝트 생성 → App → Keys and Tokens
#   ⚠️ 트윗 작성은 Basic 이상 필요 (월 $100). Free 티어는 읽기 전용
# TWITTER_API_KEY=your-twitter-api-key
# TWITTER_API_SECRET=your-twitter-api-secret
# TWITTER_ACCESS_TOKEN=your-twitter-access-token
# TWITTER_ACCESS_TOKEN_SECRET=your-twitter-access-token-secret
